{
  "manifest_version": 3,
  "name": "Khagol — Hindu Panchang & Sky Map",
  "version": "1.0.0",
  "description": "Offline Hindu Panchang + sky map: tithi, nakshatra, yoga, karana, vara, rashi band & kundali — all computed locally, no tracking.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Khagol — Hindu Panchang & Sky Map",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "permissions": ["storage", "geolocation"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "khagol@hindu-panchangam.local",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
